# Feishu app configuration
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Access control
FCA_ALLOWED_OPEN_IDS=
FCA_ALLOWED_GROUP_CHAT_IDS=
FCA_ALLOWED_WORKDIRS=F:\development\f-codex
FCA_DEFAULT_WORKDIR=F:\development\f-codex

# Codex app-server
FCA_CODEX_BIN=codex
FCA_CODEX_LISTEN=stdio://
FCA_CODEX_MODEL=
FCA_VERSION=0.1.0

# Runtime
FCA_LOG_LEVEL=info
FCA_TURN_TIMEOUT_SECONDS=900
FCA_THREAD_STORE_PATH=data/threads.json
FCA_MESSAGE_DEDUP_STORE_PATH=data/message-dedup.json
FCA_MESSAGE_DEDUP_TTL_SECONDS=86400
